{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "outDir": "dist",
    "rootDir": ".",
    "resolveJsonModule": true
  },
  "include": ["src/**/*.ts", "scripts/**/*.ts", "test/**/*.ts", "site/**/*.ts", "site/**/*.tsx", "vite.config.ts", "vitest.config.ts", "eslint.config.js"],
  "exclude": ["node_modules", "dist", "storage"]
}
